@startuml SecuenciaCerrarCaso
actor Usuario
participant ":EventoController" as ctrl
participant ":EventoService" as svc
participant ":AccionCorrectivaRepository" as repo

Usuario -> ctrl : POST /evento/{id}/cerrar

ctrl -> svc : cerrarCaso(id)
svc -> repo : contarPendientes(evento.id)
repo --> svc : cantidadPendientes

alt No hay acciones pendientes
    svc -> svc : evento.cerrar()
    svc -> repo : guardar(evento)
    repo --> svc : eventoCerrado
    svc --> ctrl : casoCerrado
    ctrl --> Usuario : redirect /evento/detalle/{id}?cerrado
else Hay acciones pendientes
    svc --> ctrl : error
    ctrl --> Usuario : redirect /evento/detalle/{id}?error=pendientes
end
@enduml
