@startuml SecuenciaRegistrarEvento
actor Usuario
participant ":EventoController" as ctrl
participant ":EventoService" as svc
participant ":EventoRepository" as repo

Usuario -> ctrl : GET /evento/nuevo
ctrl --> Usuario : mostrarFormulario.html

Usuario -> ctrl : POST /evento/guardar(eventoDTO)
ctrl -> svc : guardar(eventoDTO)

alt Validación exitosa
    svc -> svc : generarCodigo()
    svc -> repo : save(evento)
    repo --> svc : eventoGuardado
    svc --> ctrl : eventoGuardado
    ctrl --> Usuario : redirect /evento/lista?exito
else Datos inválidos
    ctrl --> Usuario : redirect /evento/nuevo?error
end
@enduml
