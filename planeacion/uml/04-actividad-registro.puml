@startuml ActividadesRegistro
start
:Iniciar Sesión (Login);

if (¿Credenciales válidas?) then (No)
    :Mostrar mensaje de error;
    stop
else (Sí)
endif

:Mostrar Menú Principal;
:Seleccionar "Registrar Evento";
:Ingresar datos del evento;

if (¿Datos válidos?) then (No)
    :Mostrar errores de validación;
    :Volver al formulario;
    stop
else (Sí)
endif

:Guardar Evento;
:Generar Código (ACC-001);
:Mostrar mensaje "Registro exitoso";

if (¿Registrar otro?) then (Sí)
    :Limpiar formulario;
    :Volver a ingresar datos;
else (No)
endif

:Volver al Menú Principal;
stop
@enduml
